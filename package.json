{
  "name": "securenexus",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "prisma generate && WATCHPACK_POLLING=true next dev -p 3005",
    "preview": "npm run build && lsof -ti:3005 | xargs kill -9 2>/dev/null || true && next start -p 3005",
    "build": "prisma generate && next build",
    "start": "next start -H 0.0.0.0 -p 3005",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "postinstall": "mkdir -p .home .cache && HOME=\"$(pwd)/.home\" XDG_CACHE_HOME=\"$(pwd)/.cache\" prisma generate"
  },
  "dependencies": {
    "@aws-sdk/client-ec2": "^3.1068.0",
    "@aws-sdk/client-eks": "^3.1068.0",
    "@aws-sdk/client-sts": "^3.1068.0",
    "@kubernetes/client-node": "^0.22.0",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-checkbox": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.1",
    "@radix-ui/react-tooltip": "^1.1.3",
    "@tanstack/react-query": "^5.59.0",
    "@types/nodemailer": "^8.0.1",
    "@types/pdfkit": "^0.17.6",
    "bcryptjs": "^2.4.3",
    "chart.js": "^4.5.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.454.0",
    "next": "14.2.35",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.11",
    "pdfkit": "^0.19.1",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7",
    "yaml": "^2.9.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.9.0",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.35",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3"
  }
}
