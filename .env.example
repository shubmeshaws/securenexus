# Bootstrap only — everything else is configured in Admin → Settings
#
# --- Local dev (npm run dev) ---
# Use localhost in DATABASE_URL below.
#
# --- Docker Compose (docker compose up -d) ---
# 1. Copy this file: cp .env.example .env
# 2. Set JWT_SECRET, GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET, NEXT_PUBLIC_APP_URL
# 3. DATABASE_URL is overridden in docker-compose.yml to use host "db" (not localhost)
# 4. After editing .env: docker compose up -d   (restart only, no rebuild)
# 5. First run schema: docker compose exec app npx prisma db push
#
# --- Docker run (single container, external Postgres) ---
# docker run --env-file .env -p 3005:3005 securenexusapp/securenexus:latest
# Set DATABASE_URL to your real Postgres host before running.

# Database (required at startup)
# macOS Homebrew: postgresql://YOUR_MAC_USERNAME@localhost:5432/securenexus?schema=public
# Docker (docker compose up -d): postgresql://postgres:postgres_secure_pass@localhost:5432/securenexus?schema=public
DATABASE_URL=postgresql://postgres:postgres_secure_pass@localhost:5432/securenexus?schema=public

# Auth signing secret (keep in env / secrets manager, not in admin UI)
JWT_SECRET=super-secret-jwt-key-change-in-production

# App URL for Google OAuth redirect
NEXT_PUBLIC_APP_URL=http://localhost:3005

# Google SSO (required for login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
