// SecureNexus PostgreSQL schema — apply with: npm run db:push
// Key models: User, Schedule (eks | non_eks), AwsCredential, Cluster, ArgoCDInstance, SystemSetting

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Schedule {
  id              String    @id @default(cuid())
  name            String
  platformType    String    @default("eks") // eks | non_eks
  cluster         String
  namespace       String
  scope           String    @default("workload") // workload | namespace
  appName         String    // workload name, EC2 instance name, or "*" for entire namespace
  workloadKind    String    @default("Deployment") // Deployment | StatefulSet | DaemonSet | ScaledObject | Namespace | EC2
  excludedWorkloads String[] @default([]) // workload keys: Kind::name
  savedWorkloadReplicas Json? // per-workload replica counts for namespace scope
  awsCredentialId String?
  ec2InstanceId  String?
  ec2Region       String?
  shutdownTime    String    // 24h format HH:mm (daily) or derived display for one-time
  startupTime     String    // 24h format HH:mm (daily) or derived display for one-time
  recurrence      String    @default("daily") // daily | onetime | split | window | combined
  weekendShutdownTime String? // split mode: weekend-window shutdown HH:mm (other days use shutdownTime)
  weekendStartupTime  String? // split mode: weekend-window startup HH:mm (other days use startupTime)
  weekendDays     Int[]     @default([]) // split mode: ISO days (1=Mon…7=Sun) that use the weekend window
  shutdownDayOfWeek Int?    // window/combined: ISO day (1=Mon…7=Sun) for long stop
  startupDayOfWeek  Int?    // window/combined: ISO day (1=Mon…7=Sun) for long start
  windowRepeatWeekly Boolean @default(true) // window mode: repeat every week; false = one-time window
  overnightDays   Int[]     @default([]) // combined: ISO days with same-day overnight stop (e.g. Tue–Fri 00:00–07:00)
  overnightShutdownTime String? // combined: overnight stop HH:mm
  overnightStartupTime  String? // combined: overnight start HH:mm
  oneTimeShutdownAt DateTime?
  oneTimeStartupAt  DateTime?
  oneTimeCompleted  Boolean   @default(false)
  timezone        String    @default("UTC")
  daysOfWeek      Int[]     // 1=Mon, 7=Sun
  syncPolicy      String    @default("automated") // "automated" | "none"
  argocdInstanceId String?
  pausedArgoApps  String[]  @default([]) // Argo apps paused on shutdown, resumed on startup
  targetReplicas  Int       @default(1)
  enabled         Boolean   @default(true)
  teamsAlertEnabled Boolean @default(true) // Teams alerts for automatic (scheduled cron) shutdown/startup
  teamsManualAlertEnabled Boolean @default(false) // Teams alerts for manual stop/start from the UI
  liveActive      Boolean   @default(false) // visible on Live Schedules (stopped window)
  liveStartupAt   DateTime? // fixed startup target for live countdown (set on shutdown)
  liveStopSource  String?   // manual | scheduled — how the current live stop was triggered
  liveStoppedBy   String?   // email of user who ran manual shutdown (when liveStopSource=manual)
  savedReplicas   Int?      // replicas before shutdown, restored on startup
  lastRun         DateTime?
  nextRun         DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  userGrants      UserScheduleGrant[]

  @@index([enabled])
  @@index([liveActive])
  @@index([cluster, namespace, appName])
  @@index([platformType])
  @@index([awsCredentialId])
}

/// Ephemeral start/stop of a single workload — does not modify Schedule records.
model InstantRun {
  id               String    @id @default(cuid())
  cluster          String
  namespace        String
  appName          String
  workloadKind     String    @default("Deployment")
  replicasBefore   Int       @default(0)
  targetReplicas   Int       @default(1)
  pausedArgoApps   String[]  @default([])
  active           Boolean   @default(true)
  startedBy        String
  startedAt        DateTime  @default(now())
  stoppedAt        DateTime?
  stoppedBy        String?

  @@index([active])
  @@index([cluster, namespace, appName])
}

model AwsCredential {
  id              String   @id @default(cuid())
  name            String   @unique
  accessKeyId     String
  secretAccessKey String
  defaultRegion   String   @default("ap-south-1")
  awsAccountId    String?
  iamUsername     String?
  iamRoleName     String?
  updatedBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([name])
}

model ActivityLog {
  id           String   @id @default(cuid())
  timestamp    DateTime @default(now())
  action       String
  cluster      String
  namespace    String
  appName      String
  triggeredBy  String
  status       String
  message      String?
  userId       String?
  userName     String?
  userEmail    String?
  userRole     String?
  ipAddress    String?
  resourceType String?
  details      String?

  @@index([timestamp(sort: Desc)])
  @@index([cluster, namespace, appName])
  @@index([userEmail])
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  displayName  String
  passwordHash String
  role         String    @default("viewer") // admin | analyst | viewer
  active       Boolean   @default(true)
  permissions  Json?
  lastLogin    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  scheduleGrants UserScheduleGrant[]
}

/// Per-user allowlist when scheduleAccessMode is "selected" — limits which schedules a user can see and act on.
model UserScheduleGrant {
  id         String   @id @default(cuid())
  userId     String
  scheduleId String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  schedule   Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@unique([userId, scheduleId])
  @@index([userId])
  @@index([scheduleId])
}

model Cluster {
  id             String    @id @default(cuid())
  name           String    @unique
  provider       String    // kubeconfig | aws
  region         String?
  status         String    @default("connected") // connected | disconnected | error
  contextName    String?
  serverUrl      String?
  kubeconfigB64  String?
  kubeconfigPath String?
  awsAccessKeyId String?
  awsSecretKey   String?
  awsClusterName String?
  addedBy        String?
  addedByName    String?
  lastSyncAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([provider])
  @@index([status])
}

model ClusterNodeHourlySample {
  id           String   @id @default(cuid())
  clusterName  String
  calendarDate String   // yyyy-MM-dd in COST_CALENDAR_TZ
  hour         Int      // 0–23 local calendar hour
  minuteSlot   Int      @default(0) // 0, 15, 30, or 45 — quarter-hour within the hour
  nodeCount    Int
  sampledAt    DateTime @default(now())

  @@unique([clusterName, calendarDate, hour, minuteSlot])
  @@index([clusterName, calendarDate])
}

model ClusterPodHourlySample {
  id           String   @id @default(cuid())
  clusterName  String
  calendarDate String   // yyyy-MM-dd in IST
  hour         Int      // 0–23 IST calendar hour
  minuteSlot   Int      @default(0) // 0, 15, 30, or 45
  podCount     Int
  sampledAt    DateTime @default(now())

  @@unique([clusterName, calendarDate, hour, minuteSlot])
  @@index([clusterName, calendarDate])
}

model SecurityResource {
  id            String   @id @default(cuid())
  type          String   // repository | target_url
  name          String
  repoUrl       String?
  defaultBranch String?
  targetUrl     String?
  description   String?
  enabled       Boolean  @default(true)
  createdBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  reports SecurityReport[]

  @@index([type])
  @@index([enabled])
}

model SecurityToolSetting {
  id          String    @id @default(cuid())
  toolId      String    @unique
  enabled     Boolean   @default(false)
  installedAt DateTime?
  installedOs String?
  updatedAt   DateTime  @updatedAt
}

model SecurityReport {
  id          String   @id @default(cuid())
  resourceId  String?
  toolId      String
  scanJobId   String?
  title       String
  status      String   @default("completed") // pending | completed | failed
  summary     String?
  htmlContent String   @db.Text
  highCount   Int      @default(0)
  mediumCount Int      @default(0)
  lowCount    Int      @default(0)
  createdAt   DateTime @default(now())

  resource SecurityResource? @relation(fields: [resourceId], references: [id], onDelete: SetNull)
  scanJob  SecurityScanJob?  @relation(fields: [scanJobId], references: [id], onDelete: SetNull)

  @@index([resourceId])
  @@index([toolId])
  @@index([scanJobId])
  @@index([createdAt])
}

model SecurityScanJob {
  id          String   @id @default(cuid())
  resourceIds Json
  toolIds     Json
  status      String   @default("queued") // queued | running | completed | failed
  progress    Int      @default(0)
  message     String?
  error       String?
  reportCount Int      @default(0)
  pairTotal   Int      @default(0)
  reportMode  String   @default("separate") // separate | merged
  createdBy   String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  reports SecurityReport[]

  @@index([status])
  @@index([createdAt])
}

model SecurityAutomation {
  id                String    @id @default(cuid())
  name              String
  enabled           Boolean   @default(true)
  scheduleTime      String
  scheduleDays      Json
  timezone          String    @default("UTC")
  resourceIds       Json
  scanCategories    Json
  toolIds           Json
  s3Enabled         Boolean   @default(false)
  s3Bucket          String?
  s3Region          String?
  s3Prefix          String?
  s3AccessKeyId     String?
  s3SecretAccessKey String?
  teamsEnabled      Boolean   @default(false)
  teamsWebhookUrl   String?
  lastRunAt         DateTime?
  nextRunAt         DateTime?
  createdBy         String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([enabled])
  @@index([nextRunAt])
}

model EnvironmentMetrics {
  id             String   @id @default("global")
  state          String   @default("running") // running | stopped
  stateSince     DateTime @default(now())
  totalRunningMs BigInt   @default(0)
  totalStoppedMs BigInt   @default(0)
  updatedAt      DateTime @updatedAt
}

model ArgoCDInstance {
  id           String   @id @default(cuid())
  name         String   @unique
  serverUrl    String
  tokenEnc     String
  insecureTls  Boolean  @default(false)
  enabled      Boolean  @default(true)
  clusterNames String[] @default([])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([enabled])
}

model SystemSetting {
  key       String   @id
  value     String   @default("")
  isSecret  Boolean  @default(false)
  updatedBy String?
  updatedAt DateTime @updatedAt
}

model ResourceChangeAudit {
  id                        String   @id @default(uuid())
  argocdApp                 String
  cluster                   String
  environment               String
  namespace                 String
  workload                  String
  containerName             String
  resourceType              String   // CPU_REQUEST | CPU_LIMIT | MEMORY_REQUEST | MEMORY_LIMIT | REPLICAS
  oldValue                  String
  newValue                  String
  revisionSha               String
  branchName                String?
  podCount                  Int?
  authorName                String
  authorEmail               String?
  commitMessage             String?  @db.Text
  syncedAt                  DateTime
  estimatedCostImpactPerDay Decimal? @db.Decimal(12, 4)
  createdAt                 DateTime @default(now())

  @@index([cluster, namespace, syncedAt])
  @@index([syncedAt(sort: Desc)])
  @@index([authorEmail])
  @@index([argocdApp])
}

model ResourceAppRevision {
  id              String   @id @default(cuid())
  argocdApp       String   @unique
  cluster         String?
  namespace       String?
  lastRevisionSha String
  branchName      String?
  lastSyncedAt    DateTime
  updatedAt       DateTime @updatedAt

  @@index([cluster, namespace])
}

model ResourceAppCatalog {
  id        String   @id @default(cuid())
  argocdApp String   @unique
  cluster   String
  namespace String
  updatedAt DateTime @updatedAt

  @@index([cluster, namespace])
}

model ResourceSnapshot {
  id            String   @id @default(cuid())
  argocdApp     String
  namespace     String
  workload      String
  containerName String
  resourceType  String
  value         String
  capturedAt    DateTime @default(now())

  @@unique([argocdApp, namespace, workload, containerName, resourceType])
}

model BitbucketConnection {
  id           String   @id @default("default")
  username     String
  authUsername String?
  tokenEnc     String
  tokenType    String   @default("user_api") // user_api | workspace_access
  workspace    String?
  status     String   @default("disconnected") // connected | disconnected | error
  lastTestAt DateTime?
  lastError  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  repositories GitRepository[]
}

model GitRepository {
  id              String    @id @default(cuid())
  name            String
  workspace       String
  repoSlug        String
  repoUrl         String
  defaultBranch   String?
  pullIntervalMin Int       @default(1440)
  enabled         Boolean   @default(true)
  clonePath       String?
  clonedAt        DateTime?
  syncStatus      String    @default("idle") // idle | cloning | pulling
  syncStartedAt   DateTime?
  lastPullAt      DateTime?
  lastCommitSha   String?
  lastPullStatus  String?
  lastPullError   String?   @db.Text
  connectionId    String    @default("default")
  connection      BitbucketConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  gitResourceChanges GitResourceChange[]
  appSources         ArgoCDAppSource[]

  @@unique([workspace, repoSlug])
  @@index([enabled, lastPullAt])
}

model ArgoCDAppSource {
  id                 String   @id @default(cuid())
  argocdApp          String   @unique
  argocdInstanceId   String
  argocdInstanceName String
  cluster            String?
  namespace          String?
  repoUrl            String
  repoPath           String?
  targetRevision     String?
  helmValueFiles     String[] @default([])
  gitRepositoryId    String?
  gitRepository      GitRepository? @relation(fields: [gitRepositoryId], references: [id], onDelete: SetNull)
  updatedAt          DateTime @updatedAt

  @@index([gitRepositoryId])
  @@index([repoUrl])
  @@index([cluster, namespace])
}

model DevOpsContact {
  id          String   @id @default(cuid())
  name        String
  designation String   @default("")
  email       String   @default("")
  phone       String   @default("")
  imageUrl    String?  @db.Text
  sortOrder   Int      @default(0)
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([enabled, sortOrder])
}

model GitResourceChange {
  id              String   @id @default(cuid())
  gitRepositoryId String
  gitRepository   GitRepository @relation(fields: [gitRepositoryId], references: [id], onDelete: Cascade)
  commitSha       String
  branchName      String?
  authorName      String?
  authorEmail     String?
  commitMessage   String?  @db.Text
  committedAt     DateTime
  filePath        String
  workload        String?
  containerName   String
  resourceType    String
  oldValue        String
  newValue        String
  pulledAt        DateTime @default(now())
  auditLinked     Boolean  @default(false)

  @@unique([gitRepositoryId, commitSha, filePath, workload, containerName, resourceType])
  @@index([gitRepositoryId, committedAt(sort: Desc)])
  @@index([commitSha])
  @@index([auditLinked])
}
